# ============ POLYMARKET TRADING BOT CONFIG ============

# === API KEYS ===
# Google Gemini AI
GOOGLE_API_KEY=your_gemini_api_key_here

# Polymarket Private Key (NEVER commit this!)
POLYMARKET_PRIVATE_KEY=your_polymarket_private_key_here

# Optional: Binance API (for market correlation)
BINANCE_API_KEY=optional
BINANCE_API_SECRET=optional

# === CONFIGURATION ===
# Bot Settings
INITIAL_BALANCE=1000
CONFIDENCE_THRESHOLD=0.65
MAX_CONSECUTIVE_LOSSES=3
RISK_PERCENTAGE=0.02

# Polymarket Market ID (you can find this on Polymarket)
POLYMARKET_MARKET_ID=

# Network: 'polygon-mainnet' or 'polygon-mumbai' (testnet)
POLYMARKET_NETWORK=polygon-mainnet

# === DATABASE ===
DATABASE_PATH=./data/polymarket_bot.db
LOG_LEVEL=INFO

# === DEPLOYMENT ===
# run.claw.cloud settings (if deploying)
PORT=8000
HOST=0.0.0.0
DEBUG=False
